{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/mini-stock-ms/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/mini-stock-ms/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/mini-stock-ms",
  "projects": {
    "api-gateway": {
      "type": "application",
      "root": "apps/api-gateway",
      "entryFile": "main",
      "sourceRoot": "apps/api-gateway/src",
      "compilerOptions": {
        "tsConfigPath": "apps/api-gateway/tsconfig.app.json"
      }
    },
    "auth": {
      "type": "application",
      "root": "apps/auth",
      "entryFile": "main",
      "sourceRoot": "apps/auth/src",
      "compilerOptions": {
        "tsConfigPath": "apps/auth/tsconfig.app.json"
      }
    },
    "mini-stock-ms": {
      "type": "application",
      "root": "apps/mini-stock-ms",
      "entryFile": "main",
      "sourceRoot": "apps/mini-stock-ms/src",
      "compilerOptions": {
        "tsConfigPath": "apps/mini-stock-ms/tsconfig.app.json"
      }
    },
    "stocks": {
      "type": "application",
      "root": "apps/stocks",
      "entryFile": "main",
      "sourceRoot": "apps/stocks/src",
      "compilerOptions": {
        "tsConfigPath": "apps/stocks/tsconfig.app.json"
      }
    },
    "wallet": {
      "type": "application",
      "root": "apps/wallet",
      "entryFile": "main",
      "sourceRoot": "apps/wallet/src",
      "compilerOptions": {
        "tsConfigPath": "apps/wallet/tsconfig.app.json"
      }
    }
  }
}